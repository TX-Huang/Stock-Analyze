# 永豐金證券 Shioaji API (實盤交易、即時報價)
SINOPAC_API_KEY = ""
SINOPAC_SECRET_KEY = ""

# Telegram Bot (推播通知)
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""
