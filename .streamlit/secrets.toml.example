# 並在下方填入您自己的 API 金鑰
#
# 取得方式:
#   Gemini  → https://aistudio.google.com/apikey
#   FinLab  → https://www.finlab.tw/ (會員中心)
#   永豐金  → https://www.sinotrade.com.tw/ (Shioaji API)
#   Telegram → @BotFather (建立 Bot 取得 Token)
# ==========================================

# Google Gemini AI (股市戰情室 AI 分析)
GEMINI_API_KEY = ""

# FinLab 台股資料 (量化回測、策略運算)
